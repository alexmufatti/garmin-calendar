# Garmin Connect credentials
GARMIN_EMAIL=tuaemail@example.com
GARMIN_PASSWORD=tuapassword

# FastMail CalDAV (usa una App Password, non la password principale)
# Impostazioni > Password & Sicurezza > App Passwords > Add
FASTMAIL_EMAIL=tuaemail@fastmail.com
FASTMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Nome del calendario FastMail da usare (lascia vuoto per usare il primo trovato)
FASTMAIL_CALENDAR_NAME=

# Orario default per i nuovi eventi (formato HH:MM:SS)
DEFAULT_TIME=07:00:00

# Quanti giorni in avanti sincronizzare
DAYS_AHEAD=60

# Minuti extra da aggiungere a fine allenamento (cambio + doccia)
EXTRA_MINUTES=30

# Eliminare eventi da calendario quando rimossi da Garmin? (true/false)
DELETE_REMOVED=false
