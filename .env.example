# Garmin Connect credentials
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=yourpassword

# CalDAV server
# FastMail:  https://caldav.fastmail.com
# Nextcloud: https://nextcloud.example.com/remote.php/dav
# iCloud:    https://caldav.icloud.com
# Proton:    https://calendar.proton.me/dav
CALDAV_URL=https://caldav.fastmail.com

CALDAV_USERNAME=you@fastmail.com
CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Name of the calendar to use (leave empty to use the first one found)
CALDAV_CALENDAR_NAME=

# Default start time for new events (HH:MM:SS)
DEFAULT_TIME=07:00:00

# How many days ahead to sync
DAYS_AHEAD=60

# Extra minutes added to event duration (e.g. for changing + shower)
EXTRA_MINUTES=30

# Delete events from calendar when removed from Garmin? (true/false)
DELETE_REMOVED=false
